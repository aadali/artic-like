name 00texlive.config
category Package
depend minrelease/2016
depend release/2021

name 00texlive.installation
category TLCore
depend opt_autobackup:1
depend opt_backupdir:tlpkg/backups
depend opt_create_formats:1
depend opt_desktop_integration:1
depend opt_file_assocs:1
depend opt_generate_updmap:0
depend opt_install_docfiles:1
depend opt_install_srcfiles:1
depend opt_location:https://mirrors.nju.edu.cn/CTAN/systems/texlive/tlnet
depend opt_post_code:1
depend opt_sys_bin:/usr/local/bin
depend opt_sys_info:/usr/local/share/info
depend opt_sys_man:/usr/local/share/man
depend opt_w32_multi_user:1
depend setting_available_architectures:x86_64-linux

name adobemapping
category Package
revision 51787
shortdesc Adobe cmap and pdfmapping files
longdesc The package comprises the collection of CMap and PDF mapping
longdesc files made available for distribution by Adobe.
containersize 2169892
containerchecksum 1dd2c4a813bbcd8063d42c1872fd14427bae2e5ce9698ddb0825770653d17798c037da511d43a0939cea1a607f0a7bb7ce974bff72a2ee88c6f56f941cc7510e
runfiles size=5246
